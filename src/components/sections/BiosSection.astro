---
import { getUI } from "~/i18n";
import { DEFAULT_LOCALE } from "~/i18n/locales";
import { withRef } from "~/lib/links";
import { brand } from "~/brand.config";

interface Props {
  lang?: string;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const t = getUI(lang).bios;

const creditLabel = brand.links.mainSite.replace(/^https?:\/\//, "").replace(/\/$/, "");
const creditUrl = withRef(brand.links.bioCreditUrl, "bios-credit");

// Bare, generic bio cards — one per entry in brand.config.bios (any number).
// Name comes from config; role + body come from the i18n `bios` dict by index
// (falling back to the config title / empty when a locale has fewer entries).
// No portrait dependency: a simple initial-letter avatar keeps the foundation
// asset-free until the brand-kit process supplies real headshots.
const bios = brand.bios.map((b, i) => ({
  name: b.name,
  role: t.roles[i] ?? b.title,
  body: t.bodies[i] ?? "",
}));

function initials(name: string): string {
  return name
    .replace(/(Dr\.|Mr\.|Ms\.|Mrs\.|M\.D\.|PhD|,.*$)/g, "")
    .trim()
    .split(/\s+/)
    .map((w) => w[0])
    .filter(Boolean)
    .slice(0, 2)
    .join("")
    .toUpperCase();
}

// 1 bio → single centered card; 2+ → two-column grid.
const gridCols = bios.length === 1 ? "md:grid-cols-1 max-w-md mx-auto" : "md:grid-cols-2";
---

<section id="bios" class="bg-white py-20">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-df-text md:text-4xl">
        {t.headline}
      </h2>
      <p class="mt-4 text-lg text-gray-700">
        {t.subheading}
      </p>
    </div>

    <div class={`mt-12 grid gap-8 ${gridCols}`}>
      {
        bios.map((bio) => (
          <article class="rounded-2xl bg-df-cream p-8 shadow-sm ring-1 ring-black/5">
            <div class="flex items-center gap-4">
              {/* Initial-letter avatar — replace with a real headshot from the
                  brand kit by swapping this span for an <img>. */}
              <span
                class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-df-green-dark text-lg font-bold text-white"
                aria-hidden="true"
              >
                {initials(bio.name)}
              </span>
              <div class="min-w-0">
                <h3 class="text-2xl font-bold leading-tight text-df-text [overflow-wrap:anywhere]">{bio.name}</h3>
                {bio.role && (
                  <p class="mt-1 text-sm font-medium uppercase tracking-wider text-df-green-dark">
                    {bio.role}
                  </p>
                )}
              </div>
            </div>
            {bio.body && (
              <p class="mt-4 text-base leading-relaxed text-gray-700">
                {bio.body}
              </p>
            )}
          </article>
        ))
      }
    </div>

    <p class="mt-10 text-center text-sm text-gray-500">
      {t.footerPrefix}{" "}
      <a
        href={creditUrl}
        target="_blank"
        rel="noopener"
        class="font-medium text-df-green-dark hover:underline"
      >
        {creditLabel}
      </a>
      .
    </p>
  </div>
</section>
